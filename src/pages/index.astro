<script>
  (function () {
    const testimonials = [
      {
        quote: '"BOS changed the way I see my land. I\'ve tripled my harvest using indigenous soil practices. My children now have hope."',
        name: "Sarah Namukasa",
        role: "Community Farmer, Uganda"
      },
      {
        quote: '"The Bill of Senga bridges two worlds I\'ve spent my career trying to connect. This is the future of sustainable farming in Africa."',
        name: "Dr. James Ochieng",
        role: "Agricultural Scientist, Kenya"
      },
      {
        quote: '"I started a rooftop garden after learning from BOS. Now I supply vegetables to 15 families in my building every week."',
        name: "Amara Diallo",
        role: "Urban Farmer, Ghana"
      }
    ];

    const container = document.getElementById('testimonial-container');
    const quoteEl = document.getElementById('testimonial-quote');
    const nameEl = document.getElementById('testimonial-name');
    const roleEl = document.getElementById('testimonial-role');
    const buttons = document.querySelectorAll('.testimonial-btn');
    const rings = document.querySelectorAll('.avatar-ring');
    const images = document.querySelectorAll('.testimonial-btn img');

    let current = 0;
    let timer;

    function switchTestimonial(index) {
      if (index === current) return;

      container.classList.add('opacity-0');

      setTimeout(() => {
        current = index;
        const t = testimonials[current];
        quoteEl.textContent = t.quote;
        nameEl.textContent = t.name;
        roleEl.textContent = t.role;

        buttons.forEach((btn, i) => {
          rings[i].style.opacity = i === current ? '1' : '0';
          if (i === current) {
            images[i].classList.remove('grayscale');
          } else {
            images[i].classList.add('grayscale');
          }
        });

        container.classList.remove('opacity-0');
      }, 500);
    }

    function startAuto() {
      clearInterval(timer);
      timer = setInterval(() => {
        switchTestimonial((current + 1) % testimonials.length);
      }, 7000);
    }

    buttons.forEach((btn, i) => {
      btn.addEventListener('click', () => {
        switchTestimonial(i);
        startAuto();
      });
    });

    startAuto();
  })();
</script>


