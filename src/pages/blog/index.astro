<script>
  document.addEventListener('DOMContentLoaded', () => {
    // --- NATIVE POSTS SEED DATA ---
    const nativePosts = [
      {
        id: 'post-1-healthy-soil',
        title: 'From "Hell" to a Living Laboratory: The Story of My Land in Senga',
        category: 'The Story of Senga',
        publishDate: '2026-05-15T09:00:00.000Z',
        description: 'A personal journey of doubt, loss, persistence, and restoring life to an exhausted piece of land.',
        author: 'William Odinga Balikuddembe',
        readTime: 6,
        featuredImage: '/blog_soil.png',
        isCustom: false,
        link: '/blog/post-1-healthy-soil.html',
        initialViews: 142
      },
      {
        id: 'post-2-tree-billionaire',
        title: 'How to Become a Tree Billionaire in 5 Years',
        category: 'Forestry & Climate',
        publishDate: '2026-06-02T10:00:00.000Z',
        description: 'Planting trees is not just an act of love for the environment — it is a generational investment. Learn how BOS is turning ordinary farmers into Tree Billionaires.',
        author: 'BOS Editorial Team',
        readTime: 7,
        featuredImage: '/blog_tree.png',
        isCustom: false,
        link: '/blog/post-2-tree-billionaire.html',
        initialViews: 89
      },
      {
        id: 'post-3-urban-rooftop',
        title: 'Urban Rooftop Farming: Feeding Cities from Above',
        category: 'Urban Farming',
        publishDate: '2026-06-20T11:00:00.000Z',
        description: 'Cities need not be food deserts. Discover how BOS Smart Villages are transforming rooftops into productive organic gardens that feed families and build community.',
        author: 'BOS Editorial Team',
        readTime: 5,
        featuredImage: '/blog_rooftop.png',
        isCustom: false,
        link: '/blog/post-3-urban-rooftop.html',
        initialViews: 64
      }
    ];

    // Ensure all native views are initialized
    nativePosts.forEach(p => {
      const vKey = `bos_views_${p.id}`;
      if (!localStorage.getItem(vKey)) {
        localStorage.setItem(vKey, p.initialViews);
      }
    });

    // Parse URL parameters
    const urlParams = new URLSearchParams(window.location.search);
    let activeCategory = urlParams.get('category') || '';
    let activeSearch = urlParams.get('search') || '';

    // Bind inputs
    const mainSearchInput = document.getElementById('blog-search-input');
    const sidebarSearchInput = document.getElementById('blog-sidebar-search');

    if (mainSearchInput) {
      mainSearchInput.value = activeSearch;
      mainSearchInput.addEventListener('input', (e) => {
        activeSearch = e.target.value;
        renderFeed();
      });
    }

    if (sidebarSearchInput) {
      sidebarSearchInput.value = activeSearch;
      sidebarSearchInput.addEventListener('input', (e) => {
        activeSearch = e.target.value;
        if (mainSearchInput) mainSearchInput.value = activeSearch;
        renderFeed();
      });
    }

    function loadCustomPosts() {
      return JSON.parse(localStorage.getItem('bos_custom_posts') || '[]');
    }

    function renderFeed() {
      const customPosts = loadCustomPosts();
      
      // Filter out draft or future scheduled custom posts
      const activeCustom = customPosts.filter(p => {
        const isDraft = p.status === 'draft';
        const isScheduled = p.status === 'scheduled' || (p.status === 'published' && new Date(p.publishDate) > new Date());
        return !isDraft && !isScheduled;
      }).map(p => ({
        ...p,
        isCustom: true,
        link: `/blog/view.html?id=${p.id}`
      }));

      // Combine
      let allPosts = [...nativePosts, ...activeCustom];

      // Sort by publish date (newest first)
      allPosts.sort((a, b) => new Date(b.publishDate || b.createdAt) - new Date(a.publishDate || a.createdAt));

      // Compute Category counts for all matching
      const categoryCounts = {};
      allPosts.forEach(p => {
        categoryCounts[p.category] = (categoryCounts[p.category] || 0) + 1;
      });
      renderCategoriesWidget(categoryCounts);

      // Apply Search Filter
      if (activeSearch) {
        const query = activeSearch.toLowerCase().trim();
        allPosts = allPosts.filter(p => 
          p.title.toLowerCase().includes(query) || 
          p.description.toLowerCase().includes(query) ||
          p.category.toLowerCase().includes(query) ||
          (p.author && p.author.toLowerCase().includes(query))
        );
      }

      // Apply Category Filter
      if (activeCategory) {
        allPosts = allPosts.filter(p => p.category.toLowerCase() === activeCategory.toLowerCase());
      }

      // Populate sidebar popular articles widget
      renderPopularWidget(customPosts);

      const feedContainer = document.getElementById('blog-posts-feed-container');
      if (!feedContainer) return;

      if (allPosts.length === 0) {
        feedContainer.innerHTML = `
          <div class="bg-white border border-gray-100 rounded-3xl p-12 text-center shadow-sm">
            <span class="material-symbols-outlined text-gray-300 text-5xl mb-4">search_off</span>
            <h3 class="font-display text-2xl font-bold text-secondary mb-2">No Articles Found</h3>
            <p class="text-gray-500 mb-6 text-sm">We couldn't find any posts matching your search keywords or active filters.</p>
            <button id="btn-clear-filters" class="bg-primary hover:bg-[#002b54] text-white px-6 py-2.5 rounded-full font-semibold transition-colors text-xs">
              Clear All Filters
            </button>
          </div>
        `;
        document.getElementById('btn-clear-filters').addEventListener('click', () => {
          activeSearch = '';
          activeCategory = '';
          if (mainSearchInput) mainSearchInput.value = '';
          if (sidebarSearchInput) sidebarSearchInput.value = '';
          window.history.replaceState({}, document.title, '/blog/');
          renderFeed();
        });
        return;
      }

      // Render First Post as Featured
      const featured = allPosts[0];
      const otherPosts = allPosts.slice(1);

      const fDate = new Date(featured.publishDate || featured.createdAt);
      const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
      const fDay = String(fDate.getDate()).padStart(2, '0');
      const fMonth = months[fDate.getMonth()];

      const fViewsKey = `bos_views_${featured.id}`;
      const fViews = parseInt(localStorage.getItem(fViewsKey)) || featured.initialViews || 42;

      let featuredHTML = `
        <div class="mb-12">
          <p class="text-primary font-semibold text-xs uppercase tracking-widest mb-6">Featured Article</p>
          <a href="${featured.link}" class="group grid grid-cols-1 lg:grid-cols-2 gap-0 bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 border border-gray-100">
            <div class="relative h-72 lg:h-auto overflow-hidden">
              <img src="${featured.featuredImage || '/blog_soil.png'}" alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"/>
              <div class="absolute inset-0 bg-gradient-to-r from-transparent to-black/10"></div>
              <span class="absolute top-4 left-4 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">${featured.category}</span>
              <div class="absolute bottom-4 right-4 w-14 h-14 rounded-full bg-primary text-white flex flex-col items-center justify-center text-xs font-bold shadow-lg leading-tight">
                <span class="text-base font-extrabold leading-none">${fDay}</span>
                <span class="uppercase tracking-wider text-[9px]">${fMonth}</span>
              </div>
            </div>
            <div class="p-8 flex flex-col justify-center">
              <h2 class="font-display text-2xl font-bold text-secondary mb-4 leading-snug group-hover:text-primary transition-colors">${featured.title}</h2>
              <p class="text-gray-500 text-sm leading-relaxed mb-6">${featured.description}</p>
              <div class="flex items-center gap-4 text-xs text-gray-400 mb-6">
                <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">person</span> ${featured.author || 'BOS Contributor'}</span>
                <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">schedule</span> ${featured.readTime || 5} min read</span>
                <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px] text-primary">visibility</span> <span>${fViews.toLocaleString()} views</span></span>
              </div>
              <span class="inline-flex items-center gap-2 text-primary font-semibold text-sm group-hover:gap-3 transition-all">
                Read Article <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
              </span>
            </div>
          </a>
        </div>
      `;

      let gridHTML = '';
      if (otherPosts.length > 0) {
        gridHTML = `
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            ${otherPosts.map(p => {
              const pDate = new Date(p.publishDate || p.createdAt);
              const pDay = String(pDate.getDate()).padStart(2, '0');
              const pMonth = months[pDate.getMonth()];
              const pViewsKey = `bos_views_${p.id}`;
              const pViews = parseInt(localStorage.getItem(pViewsKey)) || p.initialViews || 42;

              let catBg = 'bg-primary';
              if (p.category === 'Forestry & Climate') catBg = 'bg-emerald-600';
              if (p.category === 'Urban Farming') catBg = 'bg-amber-500';

              return `
                <a href="${p.link}" class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
                  <div class="relative h-52 overflow-hidden">
                    <img src="${p.featuredImage || '/blog_soil.png'}" alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>
                    <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
                    <span class="absolute top-4 left-4 ${catBg} text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">${p.category}</span>
                    <div class="absolute bottom-0 right-6 translate-y-1/2 w-14 h-14 rounded-full ${catBg} text-white flex flex-col items-center justify-center text-xs font-bold shadow-lg z-10 leading-tight">
                      <span class="text-base font-extrabold leading-none">${pDay}</span>
                      <span class="uppercase tracking-wider text-[9px]">${pMonth}</span>
                    </div>
                  </div>
                  <div class="p-6 pt-10 flex flex-col flex-grow">
                    <h3 class="font-display text-xl font-bold text-secondary mb-3 leading-snug group-hover:text-primary transition-colors">${p.title}</h3>
                    <p class="text-gray-500 text-sm leading-relaxed mb-5 flex-grow line-clamp-3">${p.description}</p>
                    <div class="flex items-center justify-between">
                      <div class="flex items-center gap-3 text-xs text-gray-400">
                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">schedule</span> ${p.readTime || 5} min read</span>
                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px] text-primary">visibility</span> <span>${pViews.toLocaleString()} views</span></span>
                      </div>
                      <span class="inline-flex items-center gap-1 text-primary font-semibold text-sm group-hover:gap-2 transition-all">
                        Read <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                      </span>
                    </div>
                  </div>
                </a>
              `;
            }).join('')}
          </div>
        `;
      }

      feedContainer.innerHTML = featuredHTML + gridHTML;
    }

    function renderCategoriesWidget(counts) {
      const widget = document.querySelector('.lg\\:col-span-4 .flex.flex-col.gap-2');
      if (!widget) return;

      widget.innerHTML = Object.entries(counts).map(([cat, count]) => {
        const isAct = activeCategory.toLowerCase() === cat.toLowerCase();
        return `
          <button onclick="filterCategory('${cat}')" class="flex justify-between items-center px-4 py-2.5 rounded-xl hover:bg-stone-50 text-stone-600 hover:text-primary transition-all text-left ${isAct ? 'bg-stone-100 text-primary font-semibold' : ''}">
            <span>${cat}</span>
            <span class="bg-stone-100 text-stone-500 text-xs px-2 py-0.5 rounded-full font-bold">${count}</span>
          </button>
        `;
      }).join('');
    }

    window.filterCategory = (cat) => {
      activeCategory = activeCategory.toLowerCase() === cat.toLowerCase() ? '' : cat;
      const url = new URL(window.location);
      if (activeCategory) {
        url.searchParams.set('category', activeCategory);
      } else {
        url.searchParams.delete('category');
      }
      window.history.replaceState({}, document.title, url);
      renderFeed();
    };

    function renderPopularWidget(customPosts) {
      const popularWidget = document.querySelector('.lg\\:col-span-4 .flex.flex-col.gap-4');
      if (!popularWidget) return;

      // Merge native
      const mergedPopular = nativePosts.map(np => {
        const vKey = `bos_views_${np.id}`;
        let views = parseInt(localStorage.getItem(vKey)) || np.initialViews;
        return { ...np, views, link: np.link };
      });

      // Filter active custom
      customPosts.forEach(cp => {
        const isDraft = cp.status === 'draft';
        const isScheduled = cp.status === 'scheduled' || (cp.status === 'published' && new Date(cp.publishDate) > new Date());
        if (!isDraft && !isScheduled) {
          const vKey = `bos_views_${cp.id}`;
          let views = parseInt(localStorage.getItem(vKey)) || cp.initialViews || 42;
          mergedPopular.push({
            id: cp.id,
            title: cp.title,
            category: cp.category,
            featuredImage: cp.featuredImage || '/blog_soil.png',
            publishDate: cp.publishDate || cp.createdAt,
            views,
            link: `/blog/view.html?id=${cp.id}`
          });
        }
      });

      // Sort by views
      mergedPopular.sort((a, b) => b.views - a.views);

      // Top 3
      const top3 = mergedPopular.slice(0, 3);
      const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

      popularWidget.innerHTML = top3.map(postItem => {
        const d = new Date(postItem.publishDate || postItem.createdAt);
        const formattedD = `${months[d.getMonth()]} ${String(d.getDate()).padStart(2, '0')}, ${d.getFullYear()}`;

        return `
          <a href="${postItem.link}" class="flex gap-3 group">
            <img src="${postItem.featuredImage || '/blog_soil.png'}" alt="" class="w-16 h-16 object-cover rounded-xl flex-shrink-0 group-hover:opacity-90 transition-opacity border border-gray-100"/>
            <div>
              <h4 class="font-display text-sm font-semibold text-secondary group-hover:text-primary transition-colors line-clamp-2 leading-snug">${postItem.title}</h4>
              <div class="flex items-center gap-2 text-[11px] text-gray-400 mt-1">
                <span>${formattedD}</span>
                <span>•</span>
                <span class="flex items-center gap-0.5"><span class="material-symbols-outlined text-[12px] text-primary">visibility</span> <span class="pop-views-${postItem.id}">${postItem.views.toLocaleString()} views</span></span>
              </div>
            </div>
          </a>
        `;
      }).join('');
    }

    // Initial render
    renderFeed();

    // Trigger views syncing loop
    setInterval(() => {
      // Add 5 views to each post
      const customPosts = loadCustomPosts();
      
      // Native posts views increase
      nativePosts.forEach(np => {
        const vKey = `bos_views_${np.id}`;
        let viewsVal = parseInt(localStorage.getItem(vKey)) || np.initialViews;
        viewsVal += 5;
        localStorage.setItem(vKey, viewsVal);
      });

      // Custom posts views increase
      customPosts.forEach(cp => {
        const vKey = `bos_views_${cp.id}`;
        let viewsVal = parseInt(localStorage.getItem(vKey)) || cp.initialViews || 42;
        viewsVal += 5;
        localStorage.setItem(vKey, viewsVal);
      });

      renderFeed();
    }, 180000);
  });
</script>
</body>
</html>
