---
// src/pages/admin/dashboard.astro
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard - Bill of Senga</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen hidden" id="dashboardBody">
  <nav class="bg-white shadow-sm px-6 py-4 flex justify-between items-center">
    <h1 class="text-xl font-bold text-gray-800">Bill of Senga Admin</h1>
    <button id="logoutBtn" class="text-sm text-gray-600 hover:text-red-600">Log Out</button>
  </nav>

  <main class="max-w-5xl mx-auto p-6 mt-6 grid grid-cols-1 md:grid-cols-3 gap-8">
    
    <!-- Blog List Column -->
    <div class="md:col-span-1 bg-white p-4 rounded-lg shadow-sm">
      <h2 class="font-semibold text-lg mb-4">Your Blog Posts</h2>
      <button id="newPostBtn" class="w-full bg-blue-50 text-blue-600 py-2 rounded mb-4 text-sm font-medium hover:bg-blue-100">+ New Post</button>
      <div id="blogList" class="space-y-2">
        <p class="text-sm text-gray-500 italic">Loading posts...</p>
      </div>
    </div>

    <!-- Editor Column -->
    <div class="md:col-span-2 bg-white p-6 rounded-lg shadow-sm border border-gray-100">
      <h2 id="editorTitle" class="font-semibold text-xl mb-6">Create New Post</h2>
      
      <form id="postForm" class="space-y-4">
        <input type="hidden" id="postId" />
        
        <div>
          <label class="block text-sm font-medium text-gray-700">Title</label>
          <input type="text" id="title" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2 border" placeholder="Enter blog title...">
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">Image URL (Optional)</label>
          <input type="text" id="imageUrl" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2 border" placeholder="https://example.com/image.jpg">
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">Content (HTML allowed)</label>
          <textarea id="content" required rows="12" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2 border" placeholder="Write your blog post here..."></textarea>
        </div>

        <div class="flex justify-end gap-3 pt-4">
          <button type="button" id="deleteBtn" class="hidden text-red-600 hover:bg-red-50 px-4 py-2 rounded">Delete</button>
          <button type="submit" id="saveBtn" class="bg-blue-600 text-white px-6 py-2 rounded-md hover:bg-blue-700">Publish Post</button>
        </div>
      </form>
    </div>
  </main>

  <script>
    import { supabase } from '../../lib/supabase.js';

    // 1. Check Auth Status
    const checkAuth = async () => {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/admin/login';
      } else {
        document.getElementById('dashboardBody').classList.remove('hidden');
        loadBlogs();
      }
    };

    // 2. Load Blogs
    const loadBlogs = async () => {
      const { data: blogs, error } = await supabase.from('blogs').select('*').order('created_at', { ascending: false });
      const listEl = document.getElementById('blogList');
      
      if (error) {
        listEl.innerHTML = `<p class="text-red-500 text-sm">Error loading blogs.</p>`;
        return;
      }

      if (blogs.length === 0) {
        listEl.innerHTML = `<p class="text-sm text-gray-500 italic">No posts yet.</p>`;
        return;
      }

      listEl.innerHTML = blogs.map(blog => `
        <button class="w-full text-left p-3 rounded border hover:bg-gray-50 truncate edit-blog-btn" data-id="${blog.id}">
          <p class="font-medium text-sm text-gray-800 truncate">${blog.title}</p>
          <p class="text-xs text-gray-400 mt-1">${new Date(blog.created_at).toLocaleDateString()}</p>
        </button>
      `).join('');

      // Add click listeners to edit buttons
      document.querySelectorAll('.edit-blog-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const blog = blogs.find(b => b.id === btn.dataset.id);
          openEditor(blog);
        });
      });
    };

    // 3. Open Editor
    const openEditor = (blog = null) => {
      const form = document.getElementById('postForm');
      if (blog) {
        document.getElementById('editorTitle').textContent = 'Edit Post';
        document.getElementById('postId').value = blog.id;
        document.getElementById('title').value = blog.title;
        document.getElementById('imageUrl').value = blog.image_url || '';
        document.getElementById('content').value = blog.content;
        document.getElementById('saveBtn').textContent = 'Update Post';
        document.getElementById('deleteBtn').classList.remove('hidden');
      } else {
        document.getElementById('editorTitle').textContent = 'Create New Post';
        form.reset();
        document.getElementById('postId').value = '';
        document.getElementById('saveBtn').textContent = 'Publish Post';
        document.getElementById('deleteBtn').classList.add('hidden');
      }
    };

    // 4. Save/Update Post
    document.getElementById('postForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const id = document.getElementById('postId').value;
      const title = document.getElementById('title').value;
      const content = document.getElementById('content').value;
      const imageUrl = document.getElementById('imageUrl').value;
      
      // Basic slug generator
      const slug = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');

      const postData = { title, slug, content, image_url: imageUrl };

      const saveBtn = document.getElementById('saveBtn');
      saveBtn.disabled = true;
      saveBtn.textContent = 'Saving...';

      let result;
      if (id) {
        result = await supabase.from('blogs').update(postData).eq('id', id);
      } else {
        result = await supabase.from('blogs').insert([postData]);
      }

      if (result.error) {
        alert("Error saving: " + result.error.message);
      } else {
        openEditor(); // Reset
        loadBlogs(); // Refresh list
      }
      
      saveBtn.disabled = false;
    });

    // 5. Delete Post
    document.getElementById('deleteBtn').addEventListener('click', async () => {
      if (confirm('Are you sure you want to delete this post?')) {
        const id = document.getElementById('postId').value;
        await supabase.from('blogs').delete().eq('id', id);
        openEditor();
        loadBlogs();
      }
    });

    // 6. UI Listeners
    document.getElementById('newPostBtn').addEventListener('click', () => openEditor());
    
    document.getElementById('logoutBtn').addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/admin/login';
    });

    // Initialize
    checkAuth();
  </script>
</body>
</html>
